# ─────────────────────────────────────────────
# Planify — .graphifyignore
# Tells graphify which paths to skip when
# building the codebase graph.
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
frontend/node_modules/

# ── Python virtual envs ───────────────────────
.venv/
venv/
backend/.venv/
backend/venv/

# ── Next.js build output ──────────────────────
.next/
frontend/.next/
frontend/out/
frontend/build/

# ── Python bytecode / caches ──────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
backend/__pycache__/
backend/**/__pycache__/

# ── Test caches & coverage ────────────────────
.pytest_cache/
backend/.pytest_cache/
frontend/coverage/
backend/htmlcov/
.coverage
*.cover

# ── Lock files (large, auto-generated) ────────
uv.lock
backend/uv.lock
package-lock.json
frontend/package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Environment / secrets ─────────────────────
.env
.env.*
*.env
frontend/.env*
backend/.env*

# ── OS artefacts ──────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor config ───────────────────────
.vscode/
.idea/
*.swp
*.suo

# ── Git internals ─────────────────────────────
.git/

# ── Docs & planning (not source code) ─────────
docs/
phase.md
plan.md
readme.md
README.md
frontend/README.md
backend/README.md

# ── Auto-generated TypeScript declarations ────
frontend/next-env.d.ts
frontend/*.tsbuildinfo

# ── Static public assets ──────────────────────
frontend/public/

# ── Vercel deployment artefacts ───────────────
frontend/.vercel/

# ── Debug logs ────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc config-only files (low signal) ───────
frontend/postcss.config.mjs
frontend/prettier.config.js
frontend/eslint.config.mjs
frontend/components.json
frontend/tsconfig.json
frontend/next.config.ts
backend/pyproject.toml
